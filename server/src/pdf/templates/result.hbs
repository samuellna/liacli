<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Laudo de Resultado — {{protocol}}</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 11px;
      color: #2c2c2c;
      background: #ffffff;
      line-height: 1.5;
    }

    /* ── CABEÇALHO ──────────────────────────────────────── */
    .header {
      background: #1a3a5c;
      color: #ffffff;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-left .brand {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 2px;
      color: #ffffff;
    }

    .header-left .brand-sub {
      font-size: 10px;
      color: #a8c4e0;
      letter-spacing: 1px;
      margin-top: 2px;
    }

    .header-right {
      text-align: right;
    }

    .header-right .doc-title {
      font-size: 13px;
      font-weight: 600;
      color: #a8c4e0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .header-right .doc-protocol {
      font-size: 11px;
      color: #dce9f5;
      margin-top: 3px;
    }

    /* ── FAIXA DE STATUS ──────────────────────────────────── */
    .status-bar {
      background: #e8f0f8;
      border-left: 4px solid #1a3a5c;
      padding: 8px 20px;
      display: flex;
      gap: 32px;
    }

    .status-item {
      display: flex;
      flex-direction: column;
    }

    .status-label {
      font-size: 9px;
      text-transform: uppercase;
      color: #6b7a8d;
      letter-spacing: 0.8px;
      font-weight: 600;
    }

    .status-value {
      font-size: 11px;
      color: #1a3a5c;
      font-weight: 600;
      margin-top: 1px;
    }

    /* ── SEÇÕES ──────────────────────────────────────────── */
    .section {
      margin: 12px 0;
      padding: 0 0;
    }

    .section-title {
      background: #2d6a9f;
      color: #ffffff;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 5px 20px;
    }

    .section-body {
      padding: 10px 20px;
      border: 1px solid #dce3ea;
      border-top: none;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px 20px;
    }

    .info-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px 20px;
    }

    .info-item .info-label {
      font-size: 9px;
      text-transform: uppercase;
      color: #6b7a8d;
      letter-spacing: 0.7px;
      font-weight: 600;
    }

    .info-item .info-value {
      font-size: 11px;
      color: #1a1a2e;
      margin-top: 1px;
    }

    /* ── RESULTADOS DOS EXAMES ───────────────────────────── */
    .exam-block {
      margin: 12px 0;
      border: 1px solid #c9d8e8;
      border-radius: 3px;
      overflow: hidden;
    }

    .exam-block + .exam-block {
      margin-top: 14px;
    }

    .exam-header {
      background: #1a3a5c;
      color: #ffffff;
      padding: 7px 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .exam-name {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .exam-badge {
      font-size: 9px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .badge-validated {
      background: #27ae60;
      color: #ffffff;
    }

    .badge-pending {
      background: #e67e22;
      color: #ffffff;
    }

    .grupo-title {
      background: #dce9f5;
      color: #1a3a5c;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      padding: 5px 14px;
      border-top: 1px solid #c9d8e8;
    }

    table.result-table {
      width: 100%;
      border-collapse: collapse;
    }

    table.result-table thead tr {
      background: #f0f5fb;
    }

    table.result-table thead th {
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      color: #4a5a6b;
      padding: 5px 14px;
      text-align: left;
      border-bottom: 1px solid #c9d8e8;
    }

    table.result-table tbody tr {
      border-bottom: 1px solid #edf1f5;
    }

    table.result-table tbody tr:last-child {
      border-bottom: none;
    }

    table.result-table tbody tr:nth-child(even) {
      background: #f8fafc;
    }

    table.result-table tbody td {
      padding: 5px 14px;
      font-size: 10.5px;
      color: #2c2c2c;
    }

    table.result-table tbody td.td-valor {
      font-weight: 600;
      color: #1a3a5c;
    }

    table.result-table tbody td.td-ref {
      color: #5a6a7b;
      font-size: 9.5px;
    }

    .exam-obs {
      background: #fffbf0;
      border-top: 1px solid #e8dbb0;
      padding: 7px 14px;
      font-size: 10px;
      color: #6b5a20;
    }

    .exam-obs-label {
      font-weight: 700;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      margin-bottom: 2px;
    }

    /* ── RODAPÉ ─────────────────────────────────────────── */
    .footer {
      margin-top: 16px;
      padding: 10px 20px;
      border-top: 2px solid #1a3a5c;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #f5f8fc;
    }

    .footer-left {
      font-size: 9px;
      color: #6b7a8d;
    }

    .footer-right {
      font-size: 9px;
      color: #6b7a8d;
      text-align: right;
    }

    .footer-right .emit-label {
      font-size: 8px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
      color: #9aabb8;
    }

    .footer-right .emit-value {
      font-size: 10px;
      font-weight: 600;
      color: #1a3a5c;
      margin-top: 1px;
    }

    /* ── UTILITÁRIOS ─────────────────────────────────────── */
    .content-wrapper {
      padding: 0 0 12px 0;
    }
  </style>
</head>
<body>

  <!-- CABEÇALHO -->
  <div class="header">
    <div class="header-left">
      <div class="brand">LIACLI</div>
      <div class="brand-sub">Laboratório de Análise Clínica</div>
    </div>
    <div class="header-right">
      <div class="doc-title">Laudo de Resultado de Exame</div>
      <div class="doc-protocol">Protocolo: {{protocol}}</div>
    </div>
  </div>

  <!-- FAIXA DE STATUS -->
  <div class="status-bar">
    <div class="status-item">
      <span class="status-label">Protocolo</span>
      <span class="status-value">{{protocol}}</span>
    </div>
    <div class="status-item">
      <span class="status-label">Data de Cadastro</span>
      <span class="status-value">{{createdAt}}</span>
    </div>
    <div class="status-item">
      <span class="status-label">Status da Amostra</span>
      <span class="status-value">{{status}}</span>
    </div>
    <div class="status-item">
      <span class="status-label">Situação</span>
      <span class="status-value">{{approvalStatus}}</span>
    </div>
    <div class="status-item">
      <span class="status-label">Data de Coleta</span>
      <span class="status-value">{{scheduledAt}}</span>
    </div>
  </div>

  <div class="content-wrapper">

    <!-- PESQUISADOR -->
    <div class="section">
      <div class="section-title">Informações do Pesquisador</div>
      <div class="section-body">
        <div class="info-grid">
          <div class="info-item">
            <div class="info-label">Nome</div>
            <div class="info-value">{{researcher.name}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">E-mail</div>
            <div class="info-value">{{researcher.email}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Nível de Pesquisa</div>
            <div class="info-value">{{researcher.level}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Instituição</div>
            <div class="info-value">{{researcher.institution}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Telefone</div>
            <div class="info-value">{{researcher.phone}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Orientador</div>
            <div class="info-value">{{researcher.advisorName}}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- PROJETO DE PESQUISA -->
    <div class="section">
      <div class="section-title">Projeto de Pesquisa</div>
      <div class="section-body">
        <div class="info-grid-2" style="margin-bottom: 8px;">
          <div class="info-item" style="grid-column: span 2;">
            <div class="info-label">Título</div>
            <div class="info-value">{{project.title}}</div>
          </div>
        </div>
        <div class="info-grid">
          <div class="info-item">
            <div class="info-label">Curso / Programa</div>
            <div class="info-value">{{project.course}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Laboratório</div>
            <div class="info-value">{{project.researchLab}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Espécie Animal</div>
            <div class="info-value">{{project.animalSpecies}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Total de Animais</div>
            <div class="info-value">{{project.totalAnimals}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Remessas Previstas</div>
            <div class="info-value">{{project.expectedShipments}}</div>
          </div>
          <div class="info-item">
            <div class="info-label">Animais nesta Remessa</div>
            <div class="info-value">{{animalsInThisShipment}}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- RESULTADOS DOS EXAMES -->
    <div class="section">
      <div class="section-title">Resultados dos Exames</div>
      <div class="section-body" style="padding: 10px 20px;">

        {{#each results}}
        <div class="exam-block">

          <!-- Cabeçalho do exame -->
          <div class="exam-header">
            <span class="exam-name">{{examTypeName}}</span>
            {{#if validated}}
              <span class="exam-badge badge-validated">Validado</span>
            {{else}}
              <span class="exam-badge badge-pending">Pendente</span>
            {{/if}}
          </div>

          <!-- Grupos de parâmetros -->
          {{#each grupos}}
            {{#if nomeGrupo}}
            <div class="grupo-title">{{nomeGrupo}}</div>
            {{/if}}

            <table class="result-table">
              <thead>
                <tr>
                  <th style="width: 35%;">Parâmetro</th>
                  <th style="width: 20%;">Resultado</th>
                  <th style="width: 15%;">Unidade</th>
                  <th style="width: 30%;">Valor de Referência</th>
                </tr>
              </thead>
              <tbody>
                {{#each parametros}}
                <tr>
                  <td>{{nome}}</td>
                  <td class="td-valor">{{valor}}</td>
                  <td>{{unidade}}</td>
                  <td class="td-ref">{{referencia}}</td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          {{/each}}

          <!-- Observações do tipo de exame -->
          {{#if observacoes}}
          <div class="exam-obs">
            <div class="exam-obs-label">Observações</div>
            {{observacoes}}
          </div>
          {{/if}}

        </div>
        {{/each}}

      </div>
    </div>

  </div>

  <!-- RODAPÉ -->
  <div class="footer">
    <div class="footer-left">
      LIACLI — Laboratório de Análise Clínica<br />
      Este documento é gerado eletronicamente e não requer assinatura.
    </div>
    <div class="footer-right">
      <div class="emit-label">Emitido em</div>
      <div class="emit-value">{{emittedAt}}</div>
    </div>
  </div>

</body>
</html>
